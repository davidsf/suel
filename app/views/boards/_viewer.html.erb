<%# Shared pan/zoom viewer: toolbar + world with one tile per board of the
    layout (BoardLayout::Entry array). Pieces overlay via block. %>
<% total_width = layout.map { |e| e.x + e.width }.max.to_i %>
<% total_height = layout.map { |e| e.y + e.height }.max.to_i %>
<div data-controller="pan-zoom board"
     data-pan-zoom-width-value="<%= total_width %>"
     data-pan-zoom-height-value="<%= total_height %>"
     <%= tag.attributes("data-pan-zoom-key-value": local_assigns[:key]) if local_assigns[:key] %>>
  <div class="viewer-bar">
    <%= toolbar %>
    <span class="spacer"></span>
    <% if layout.any? { |e| e.board.grid.present? } %>
      <button data-action="board#toggleGrid"><%= t("viewer.grid") %></button>
      <% if layout.any? { |e| e.board.numbering? } %>
        <button data-action="board#toggleNumbering"><%= t("viewer.numbering") %></button>
      <% end %>
    <% end %>
    <button data-action="pan-zoom#zoomOut">−</button>
    <button data-action="pan-zoom#zoomIn">+</button>
    <button data-action="pan-zoom#fit"><%= t("viewer.fit") %></button>
  </div>
  <div class="viewer" data-pan-zoom-target="viewport"
       data-action="wheel->pan-zoom#wheel pointerdown->pan-zoom#pointerDown
                    pointermove->pan-zoom#pointerMove pointerup->pan-zoom#pointerUp
                    pointercancel->pan-zoom#pointerUp">
    <div class="world" data-pan-zoom-target="world">
      <% layout.each do |entry| %>
        <div class="board-tile" style="left: <%= entry.x %>px; top: <%= entry.y %>px;">
          <% if entry.board.image_filename.present? %>
            <%= image_tag board_preview_path(entry.board, game_module),
                  class: "board", alt: entry.board.name,
                  width: entry.board.width, height: entry.board.height,
                  decoding: "async",
                  data: { board_target: "image",
                          full_src: module_image_path(game_module, entry.board.image_filename) } %>
          <% elsif entry.board.width.present? %>
            <%# Imageless board (player hand): plain surface %>
            <div class="board" style="width: <%= entry.board.width %>px; height: <%= entry.board.height %>px; background: #f0ead8;"></div>
          <% end %>
          <%= grid_overlay(entry.board) %>
        </div>
      <% end %>
      <%= yield %>
    </div>
  </div>
</div>
