<h1>Módulos</h1>

<% if @game_modules.any? %>
  <div class="cards">
    <% @game_modules.each do |game_module| %>
      <div class="card">
        <% board = game_module.game_maps.flat_map(&:boards).find { |b| b.image_filename.present? } %>
        <% if board && game_module.ready? %>
          <%= link_to game_module_path(game_module) do %>
            <div class="thumb" style="background-image: url('<%= board_preview_path(board, game_module) %>')"></div>
          <% end %>
        <% else %>
          <div class="thumb"></div>
        <% end %>
        <div class="body">
          <%= link_to game_module.name || game_module.slug, game_module_path(game_module) %>
          <div class="meta">
            <span class="status-pill <%= game_module.status %>"><%= game_module.status %></span>
            <% if game_module.version.present? %>v<%= game_module.version %><% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p>Todavía no hay módulos cargados.</p>
  <% if Current.user&.admin? %>
    <p><%= link_to "Subir el primer módulo", new_admin_game_module_path %></p>
  <% end %>
<% end %>
