<p>
  <span class="status-pill <%= game_module.status %>"><%= t("modules.status.#{game_module.status}", default: game_module.status) %></span>
  <% if game_module.progress_note.present? && !game_module.ready? %>
    <%= t("modules.progress.#{game_module.progress_note}", default: game_module.progress_note) %>
  <% end %>
  <% if game_module.failed? && game_module.error_message.present? %>
    <br><small><%= game_module.error_message %></small>
  <% end %>
  <% if game_module.version.present? %>
    <small>· <%= t('modules.version_abbr') %> <%= game_module.version %> · VASSAL <%= game_module.vassal_version %></small>
  <% end %>
</p>
