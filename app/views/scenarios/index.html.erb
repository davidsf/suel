<%= turbo_frame_tag "scenario-picker" do %>
  <h2>Escenarios — <%= @game_module.name || @game_module.slug %></h2>
  <% if @scenarios.any? %>
    <% @scenarios.group_by { |s| s.category.presence }.each do |category, scenarios| %>
      <% if category %><h3 class="muted"><%= category %></h3><% end %>
      <table class="listing">
        <% scenarios.each do |scenario| %>
          <tr>
            <td><%= scenario.name %></td>
            <td class="muted"><%= scenario.scenario_pieces.count %> fichas</td>
            <td>
              <% if authenticated? %>
                <%= link_to "Crear partida", new_game_path(scenario_id: scenario.id),
                      data: { turbo_frame: "_top" } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </table>
    <% end %>
  <% else %>
    <p class="muted">El módulo no incluye escenarios listos.</p>
  <% end %>
<% end %>
