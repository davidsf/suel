<h1><%= t("games.new_title") %></h1>
<p class="muted"><%= t("games.scenario_lead", module: @scenario.game_module.name, scenario: @scenario.name) %></p>

<%= form_with model: @game, url: games_path do |form| %>
  <% if @game.errors.any? %>
    <ul>
      <% @game.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  <% end %>

  <%= form.hidden_field :scenario_id, value: @scenario.id %>
  <p>
    <%= form.label :name, t("games.name_label") %><br>
    <%= form.text_field :name, required: true, size: 50 %>
  </p>
  <p>
    <%= form.label :side, t("games.side_label") %><br>
    <%= form.select :side, @game.game_module.sides %>
  </p>
  <p><%= form.submit t("games.create") %></p>
<% end %>
