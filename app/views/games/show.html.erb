<% content_for :title, "#{@game.name}" %>

<% if @layout.empty? %>
  <p><%= link_to "← Partidas", games_path %></p>
  <h1><%= @game.name %></h1>
  <p class="muted">La partida no tiene fichas sobre tableros conocidos.</p>
<% else %>
  <% content_for :main_class, "full" %>

  <% toolbar = capture do %>
    <%= link_to "← Partidas", games_path %>
    <strong><%= @game.name %></strong>
    <% if @maps.size > 1 %>
      <span class="muted">
        <% @maps.each do |map| %>
          <% if map == @game_map %>
            <strong><%= map.name %></strong>
          <% else %>
            <%= link_to map.name, game_path(@game, map: map.id) %>
          <% end %>
        <% end %>
      </span>
    <% end %>
    <span class="muted">
      <% @game.players.each do |player| %>
        <%= player.side %>: <%= player.user.email_address.split("@").first %><%= " (tú)" if player == @player %>
        (<%= render "games/hand_count", game: @game, side: player.side %>) ·
      <% end %>
    </span>
    <% if @player.nil? %>
      <% @game.free_sides.each do |side| %>
        <%= button_to "Unirse como #{side}", game_players_path(@game, side: side),
              method: :post, form: { style: "display:inline" } %>
      <% end %>
      <% if @game.free_sides.empty? %><span class="muted">(espectador)</span><% end %>
    <% end %>
  <% end %>

  <div data-controller="game-table"
       class="<%= "game-table-has-tray" if @player %>"
       data-game-table-playable-value="<%= @player.present? %>"
       data-game-table-snap-url-value="<%= snap_game_path(@game) %>"
       data-game-table-map-value="<%= @game_map.id %>">
    <%= turbo_stream_from @game %>
    <%= turbo_stream_from @game, @player.side if @player %>

    <%= render layout: "boards/viewer",
          locals: { layout: @layout, game_module: @game_module, toolbar: } do %>
      <div id="<%= dom_id(@game_map, :pieces) %>">
        <% @pieces.each do |piece| %>
          <%= render "game_pieces/game_piece", game_piece: piece, game_module: @game_module %>
        <% end %>
      </div>
      <% @decks.each do |deck| %>
        <%= render "decks/deck_marker", deck: deck, game: @game %>
      <% end %>
    <% end %>

    <% if @player && @dice_buttons.any? %>
      <div class="dice-bar">
        <% @dice_buttons.each_with_index do |button, index| %>
          <button data-action="game-table#roll"
                  data-game-table-url-param="<%= game_rolls_path(@game, button: index) %>"
                  title="<%= button['n_dice'] %>d<%= button['n_sides'] %><%= "+#{button['plus']}" if button['plus'].positive? %>">
            🎲 <%= button["label"] %>
          </button>
        <% end %>
      </div>
    <% end %>

    <details class="game-log" open>
      <summary>Registro</summary>
      <div id="game_log" class="log-entries">
        <% @events.each do |event| %>
          <%= render "game_events/game_event", game_event: event %>
        <% end %>
      </div>
      <%= form_with url: game_messages_path(@game), method: :post, class: "chat-form",
            data: { controller: "reset-form", action: "turbo:submit-end->reset-form#reset" } do |form| %>
        <%# size: nil — Rails copia maxlength a size, y size=500 desborda el panel %>
        <%= form.text_field :body, placeholder: "Escribe un mensaje…", maxlength: 500, size: nil,
              autocomplete: "off", required: true %>
        <%= form.submit "Enviar" %>
      <% end %>
    </details>

    <div class="piece-toolbar" data-game-table-target="toolbar" hidden>
      <span data-game-table-target="pieceName" class="muted"></span>
      <button data-game-table-target="flipButton" data-action="game-table#flip">Voltear</button>
      <button data-game-table-target="rotateLeft" data-action="game-table#rotateLeft">⟲</button>
      <button data-game-table-target="rotateRight" data-action="game-table#rotateRight">⟳</button>
      <span data-game-table-target="layerButtons"></span>
      <% if @all_decks.any? %>
        <select data-game-table-target="pieceDiscardDeck">
          <% @all_decks.each do |deck| %>
            <option value="<%= deck.id %>"><%= deck.name %></option>
          <% end %>
        </select>
        <button data-game-table-target="pieceDiscardButton" data-action="game-table#discardPiece">Descartar</button>
      <% end %>
    </div>

    <% if @player %>
      <div class="deck-toolbar" data-game-table-target="deckToolbar" hidden>
        <span data-game-table-target="deckName" class="muted"></span>
        <button data-game-table-target="drawButton" data-action="game-table#draw">Robar</button>
        <button data-action="game-table#shuffleDeck">Barajar</button>
        <button data-game-table-target="reshuffleButton" data-action="game-table#reshuffleDeck">Rebarajar</button>
      </div>

      <div class="hand-tray" data-game-table-target="handTray">
        <button class="hand-tray-close" data-action="game-table#closeTray" title="Ocultar la mano">✕ Mano</button>
        <% if @hand_decks.any? %>
          <div class="hand-decks">
            <% @hand_decks.each do |deck| %>
              <%= render "decks/deck_marker", deck: deck, game: @game %>
            <% end %>
          </div>
        <% end %>
        <div id="hand_tray" class="hand-cards">
          <% @hand_cards.each do |card| %>
            <%= render "game_pieces/hand_card", game_piece: card, game_module: @game_module %>
          <% end %>
        </div>
      </div>
      <button class="hand-tray-open" data-game-table-target="handOpen"
              data-action="game-table#openTray" hidden>🂠 Mi mano</button>

      <% if @all_decks.any? %>
        <div class="hand-card-toolbar" data-game-table-target="handToolbar" hidden>
          <span data-game-table-target="handCardName" class="muted"></span>
          <select data-game-table-target="discardDeck">
            <% @all_decks.each do |deck| %>
              <option value="<%= deck.id %>"><%= deck.name %></option>
            <% end %>
          </select>
          <button data-action="game-table#discardHandCard">Descartar</button>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
