<% content_for :title, "#{@game.name}" %>

<% if @layout.empty? %>
  <p><%= link_to t("games.back"), games_path %></p>
  <h1><%= @game.name %></h1>
  <p class="muted"><%= t("games.no_known_boards") %></p>
<% else %>
  <% content_for :main_class, "full" %>

  <% toolbar = capture do %>
    <%= link_to t("games.back"), games_path %>
    <strong><%= @game.name %></strong>
    <% if @maps.size > 1 %>
      <nav class="map-tabs">
        <% @maps.each do |map| %>
          <% if map == @game_map %>
            <span class="map-tab active"><%= map_tab_icon(map, @game_module) %><%= map.name %></span>
          <% else %>
            <%= link_to game_path(@game, map: map.id), class: "map-tab" do %><%= map_tab_icon(map, @game_module) %><%= map.name %><% end %>
          <% end %>
        <% end %>
      </nav>
    <% end %>
    <span class="muted">
      <% @game.players.each do |player| %>
        <%= player.side %>: <%= player.user.email_address.split("@").first %><%= t("games.you") if player == @player %>
        <% if @module_has_hands %>(<%= render "games/hand_count", game: @game, side: player.side %>)<% end %> ·
      <% end %>
    </span>
    <% if @player.nil? %>
      <% @game.free_sides.each do |side| %>
        <%= button_to t("games.join_as", side: side), game_players_path(@game, side: side),
              method: :post, form: { style: "display:inline" } %>
      <% end %>
      <% if @game.free_sides.empty? %><span class="muted"><%= t("games.spectator") %></span><% end %>
    <% end %>
    <% if @game_module.charts? %>
      <button type="button" data-action="game-table#openCharts"><%= t("table.charts") %></button>
    <% end %>
  <% end %>

  <div data-controller="game-table"
       class="<%= "game-table-has-tray" if @player %>"
       data-game-table-playable-value="<%= @player.present? %>"
       data-game-table-snap-url-value="<%= snap_game_path(@game) %>"
       data-game-table-map-value="<%= @game_map.id %>"
       data-game-table-maps-value="<%= @destination_maps.map { |m| { id: m.id, name: m.name, url: game_path(@game, map: m.id) } }.to_json %>"
       data-game-table-decks-value="<%= @all_decks.map { |d| { id: d.id, name: d.name } }.to_json %>"
       data-game-table-relocate-url-template-value="<%= relocate_game_piece_path(@game, "PIECE_ID") %>"
       data-game-table-i18n-value="<%= { move_to_map: t("table.move_to_map"),
                                         placement_hint: t("table.placement_hint"),
                                         cancel: t("table.cancel"),
                                         toggle: t("table.toggle"),
                                         prev_level: t("table.prev_level"),
                                         next_level: t("table.next_level") }.to_json %>">
    <%= turbo_stream_from @game %>
    <%= turbo_stream_from @game, @player.side if @player %>

    <%= render layout: "boards/viewer",
          locals: { layout: @layout, game_module: @game_module, toolbar: } do %>
      <div id="<%= dom_id(@game_map, :pieces) %>">
        <% @pieces.each do |piece| %>
          <%= render "game_pieces/game_piece", game_piece: piece, game_module: @game_module %>
        <% end %>
      </div>
      <% @decks.each do |deck| %>
        <%= render "decks/deck_marker", deck: deck, game: @game %>
      <% end %>
    <% end %>

    <% if @player && (@dice_buttons.any? || @special_dice.any?) %>
      <div class="dice-bar">
        <% @dice_buttons.each_with_index do |button, index| %>
          <button data-action="game-table#roll"
                  data-game-table-url-param="<%= game_rolls_path(@game, button: index) %>"
                  title="<%= button['n_dice'] %>d<%= button['n_sides'] %><%= "+#{button['plus']}" if button['plus'].positive? %>">
            🎲 <%= button["label"] %>
          </button>
        <% end %>
        <% @special_dice.each_with_index do |button, index| %>
          <button data-action="game-table#roll"
                  data-game-table-url-param="<%= game_rolls_path(@game, special: index) %>"
                  title="<%= t("table.image_dice", count: button['dice'].size) %>">
            🎲 <%= button["label"] %>
          </button>
        <% end %>
      </div>
    <% end %>

    <details class="game-log" open>
      <summary><%= t("table.log") %></summary>
      <div id="game_log" class="log-entries">
        <% @events.each do |event| %>
          <%= render "game_events/game_event", game_event: event %>
        <% end %>
      </div>
      <%= form_with url: game_messages_path(@game), method: :post, class: "chat-form",
            data: { controller: "reset-form", action: "turbo:submit-end->reset-form#reset" } do |form| %>
        <%# size: nil — Rails copies maxlength into size, and size=500 overflows the panel %>
        <%= form.text_field :body, placeholder: t("table.chat_placeholder"), maxlength: 500, size: nil,
              autocomplete: "off", required: true %>
        <%= form.submit t("table.send") %>
      <% end %>
    </details>

    <div class="piece-toolbar piece-menu" data-game-table-target="toolbar" hidden>
      <span data-game-table-target="pieceName" class="menu-title"></span>
      <button class="menu-row clickable" data-game-table-target="flipButton" data-action="game-table#flip"><%= t("table.flip") %></button>
      <div class="menu-row" data-game-table-target="rotateRow">
        <span class="menu-label"><%= t("table.rotate") %></span>
        <span class="menu-stepper">
          <button data-game-table-target="rotateLeft" data-action="game-table#rotateLeft">⟲</button>
          <button data-game-table-target="rotateRight" data-action="game-table#rotateRight">⟳</button>
        </span>
      </div>
      <div data-game-table-target="layerButtons"></div>
    </div>

    <% if @player %>
      <div class="deck-toolbar" data-game-table-target="deckToolbar" hidden>
        <span data-game-table-target="deckName" class="muted"></span>
        <button data-game-table-target="drawButton" data-action="game-table#draw"><%= t("table.draw") %></button>
        <button data-action="game-table#shuffleDeck"><%= t("table.shuffle") %></button>
        <button data-game-table-target="reshuffleButton" data-action="game-table#reshuffleDeck"><%= t("table.reshuffle") %></button>
      </div>

      <%# Only when the module gives this side a hand (a PlayerHand window).
          The tray starts collapsed; players open it from the "Mi mano" tab. %>
      <% if @player_hand %>
      <div class="hand-tray" data-game-table-target="handTray" hidden>
        <button class="hand-tray-close" data-action="game-table#closeTray" title="<%= t("table.hand_hide") %>"><%= t("table.hand_close") %></button>
        <% if @hand_decks.any? %>
          <div class="hand-decks">
            <% @hand_decks.each do |deck| %>
              <%= render "decks/deck_marker", deck: deck, game: @game %>
            <% end %>
          </div>
        <% end %>
        <div id="hand_tray" class="hand-cards">
          <% @hand_cards.each do |card| %>
            <%= render "game_pieces/hand_card", game_piece: card, game_module: @game_module %>
          <% end %>
        </div>
      </div>
      <button class="hand-tray-open" data-game-table-target="handOpen"
              data-action="game-table#openTray"><%= t("table.hand_open") %></button>
      <% end %>
    <% end %>

    <% if @game_module.charts? %>
      <dialog class="charts-dialog" data-game-table-target="chartsDialog">
        <form method="dialog"><button class="charts-close" value="<%= t("games.close") %>">✕</button></form>
        <turbo-frame id="charts_frame" src="<%= game_module_charts_path(@game_module, frame: 1) %>" loading="lazy">
          <p class="muted"><%= t("charts.loading") %></p>
        </turbo-frame>
      </dialog>
    <% end %>
  </div>
<% end %>
